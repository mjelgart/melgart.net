---
import '../styles/global.css';
import '../styles/utils.css';

export interface Props {
  title: string;
  description: string;
  home?: boolean;
}

const { title, description, home = false } = Astro.props;
const name = 'melgart.net';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- Favicon -->
  <link rel="icon" href="/favicon-16x16.png" />

  <!-- Basic meta -->
  <title>{title}</title>
  <meta name="description" content={description} />

  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content="https://www.melgart.net/images/window%20preview.jpg" />
  <meta property="og:url" content="https://melgart.net" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta property="twitter:domain" content="melgart.net" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
</head>
<body>
  <div class="container">
    {home ? (
      <header class="homePageHeader">
        <img
          src="/images/profile.jpg"
          width="144"
          height="144"
          alt=""
        />
      </header>
    ) : (
      <header class="header">
        <h2 class="headingLg">
          <a href="/" class="colorInherit">
            {name}
          </a>
        </h2>
      </header>
    )}

    <main>
      <slot />
    </main>

    {!home && (
      <div class="backToHome">
        <a href="/">← Back to home</a>
      </div>
    )}
  </div>
</body>
</html>

<style>
  .container {
    max-width: 48rem;
    padding: 0 1rem;
    margin: 3rem auto 6rem;
  }

  .header {
    display: flex;
    flex-direction: column;
    align-items: left;
  }

  .homePageHeader {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .backToHome {
    margin: 3rem 0 0;
  }
</style>